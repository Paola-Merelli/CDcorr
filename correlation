# sensitivity analysis con blocchi da 25, 50 e 100 km

grains <- c(25000, 50000, 100000)

set.seed(123)

cor_thin_all <- map_dfr(
  grains,
  function(g) {
    map_dfr(
      1:200,
      ~ cor_one_iter(pts_df, cellsize_m = g, min_n = 30) %>%
          mutate(iter = .x,
                 grain_km = g / 1000)
    )
  }
)

cor_thin_all_summary <- cor_thin_all %>%
  group_by(bioregion, grain_km) %>%
  summarise(
    mean_r   = mean(r, na.rm = TRUE),
    median_r = median(r, na.rm = TRUE),
    q025     = quantile(r, 0.025, na.rm = TRUE),
    q975     = quantile(r, 0.975, na.rm = TRUE),
    mean_n   = mean(n, na.rm = TRUE),
    .groups = "drop"
  )

cor_thin_all_summary
